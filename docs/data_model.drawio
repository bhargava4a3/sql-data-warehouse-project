        </mxCell>
        <mxCell id="3KkN48R1lRXVecXf_ZRn-5" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Remember&lt;/h1&gt;&lt;p&gt;In customer table has only one record describing the customer&lt;/p&gt;&lt;p&gt;But Fact table might exist multiple records for each customer&lt;/p&gt;&lt;p&gt;So 1:N( one dimension and many facts)&lt;/p&gt;" vertex="1">
          <mxGeometry height="120" width="470" x="221" y="1103" as="geometry" />
        </mxCell>
        <mxCell id="3KkN48R1lRXVecXf_ZRn-7" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Options:&lt;/h1&gt;&lt;p&gt;1. Customer who haven&#39;t placed any order yet&lt;/p&gt;&lt;p&gt;2. Customer who have placed only one order&lt;/p&gt;&lt;p&gt;3. Customer who have places multiple orders&lt;/p&gt;" vertex="1">
